  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "responses": {
      "BadRequestError": {
        "description": "Lỗi dữ liệu đầu vào hoặc không tìm thấy",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BadRequestResponse"
            },
            "example": {
              "title": "Lỗi thao tác",
              "errorCode": "400",
              "message": "Dữ liệu đầu vào không hợp lệ hoặc không tìm thấy bản ghi tương ứng",
              "time": "2024-05-15T10:00:00"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Lỗi xác thực",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BadRequestResponse"
            },
            "example": {
              "title": "Lỗi xác thực",
              "errorCode": "401",
              "message": "Token không hợp lệ",
              "time": "2024-05-15T10:00:00"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Lỗi hệ thống máy chủ",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BadRequestResponse"
            },
            "example": {
              "title": "Lỗi hệ thống",
              "errorCode": "500",
              "message": "Có lỗi xảy ra trong quá trình xử lý trên máy chủ",
              "time": "2024-05-15T10:00:00"
            }
          }
        }
      }
    },
    "schemas": {
      "BadRequestResponse": {
        "type": "object",
        "required": [
          "title",
          "errorCode",
          "message",
          "time"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Ví dụ title"
          },
          "errorCode": {
            "type": "string",
            "example": "Ví dụ errorCode"
          },
          "message": {
            "type": "string",
            "example": "Ví dụ message"
          },
          "uri": {
            "type": [
              "string",
              "null"
            ],
            "example": "Ví dụ uri"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "example": "2023-01-01T10:00:00Z"
          },
          "requestId": {
            "type": [
              "string",
              "null"
            ],
            "example": "Ví dụ requestId"
          }
        }
      },
      "CanBoTomTat": {
        "type": "object",
        "required": [
          "id",
          "maCanBo",
          "hoTen",
          "maDonVi",
          "tenDonVi"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "maCanBo": {
            "type": "string",
            "example": "CB001"
          },
          "hoTen": {
            "type": "string",
            "example": "Nguyễn Văn A"
          },
          "ngaySinh": {
            "type": "string",
            "format": "date",
            "example": "1990-01-01"
          },
          "gioiTinh": {
            "type": "string",
            "example": "Nam"
          },
          "capBac": {
            "type": "string",
            "example": "Đại úy"
          },
          "chucVu": {
            "type": [
              "string",
              "null"
            ],
            "example": "Trưởng phòng"
          },
          "maDonVi": {
            "type": "string",
            "example": "DV001"
          },
          "tenDonVi": {
            "type": "string",
            "example": "Phòng Cảnh sát giao thông"
          },
          "maCongDan": {
            "type": "string",
            "example": "CD-123456"
          }
        }
      },
      "CanBoChiTiet": {
        "allOf": [
          {
            "$ref": "#/components/schemas/CanBoTomTat"
          },
          {
            "type": "object",
            "properties": {
              "danhSachTaiSan": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TaiSanRutGonDto"
                }
              },
              "thongTinCongDan": {
                "$ref": "#/components/schemas/CongDan"
              }
            }
          }
        ]
      },
      "TaiSanRutGonDto": {
        "type": "object",
        "required": [
          "maTaiSan"
        ],
        "properties": {
          "maTaiSan": {
            "type": "string",
            "example": "TS-001"
          },
          "tenTaiSan": {
            "type": "string",
            "example": "Màn hình Dell 27 inch"
          },
          "thongTinChiTiet": {
            "type": "object",
            "example": {
              "doPhanGiai": "4K",
              "hang": "Dell",
              "inch": 27
            }
          },
          "maNguoiCapPhat": {
            "type": [
              "string",
              "null"
            ],
            "example": "CB002"
          },
          "nguoiCapPhat": {
            "type": [
              "string",
              "null"
            ],
            "example": "Trần Văn B"
          },
          "ngayCapPhat": {
            "type": [
              "string",
              "null"
            ],
            "format": "date",
            "example": "2024-05-15"
          }
        }
      },
      "TaiSanDto": {
        "type": "object",
        "required": [
          "id",
          "maTaiSan"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "maTaiSan": {
            "type": "string",
            "example": "TS-001"
          },
          "tenTaiSan": {
            "type": "string",
            "example": "Màn hình Dell 27 inch"
          },
          "maDanhMucLoai": {
            "type": "string",
            "example": "LTS01"
          },
          "tenLoaiTaiSan": {
            "type": "string",
            "example": "Tên loại tài sản"
          },
          "thongTinChiTiet": {
