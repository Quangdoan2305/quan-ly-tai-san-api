              "type": "string"
            }
          },
          {
            "name": "loaiBenGiao",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "CAN_BO",
                "DON_VI",
                "KHO"
              ]
            }
          },
          {
            "name": "idBenGiao",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nguoiKyId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maDonVi",
            "in": "query",
            "description": "Lọc theo đơn vị liên quan (bên giao hoặc bên nhận)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Số thứ tự trang (bắt đầu từ 0)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Số lượng bản ghi trên một trang",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy dữ liệu thành công",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MainResponsePagingBaseResponseBienBanBanGiaoDtoResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequestError" },
          "401": { "$ref": "#/components/responses/UnauthorizedError" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        },
        "description": "API tìm kiếm và lọc danh sách các biên bản bàn giao (phục vụ nghiệp vụ văn thư)."
      },
      "post": {
        "tags": [
          "2. Dịch vụ khai thác dữ liệu thông tin tài sản qua LGSP"
        ],
        "summary": "Lập biên bản bàn giao tài sản",
        "operationId": "banGiaoTaiSan",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BienBanRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lập biên bản thành công",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MainResponseBienBanBanGiaoDtoResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "409": {
            "description": "Xung đột dữ liệu (Conflict). Xảy ra khi dữ liệu thêm mới bị trùng lặp mã số (ví dụ: so_bien_ban đã tồn tại).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "DUPLICATE_OR_CONSTRAINT_ERROR"
                    },
                    "message": {
                      "type": "string",
                      "example": "Dữ liệu đã tồn tại hoặc vi phạm ràng buộc cơ sở dữ liệu: Key (so_bien_ban)=(BB-NEW-001) already exists."
                    },
                    "data": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "description": "API thực hiện nghiệp vụ bàn giao tài sản."
      }
    },
