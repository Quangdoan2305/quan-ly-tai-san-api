              "type": "string"
            }
          },
          {
            "name": "tuNgay",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "denNgay",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "loaiBenNhan",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
